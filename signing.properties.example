# signing.properties — REAL release keystore + Sentry DSN / auth-token
#
# Place a copy of this file at the repo root as `signing.properties`
# (gitignored — see the project's .gitignore). Filling these in makes
# `:app:assembleRelease` produce a Play-shippable APK and lets the
# `io.sentry.android.gradle` plugin upload mapping.txt + InApp frames.
#
# Where each value comes from:
#
#   RELEASE_STORE_FILE       release keystore (Phase 7 · Step 7.13 —
#                            generated with `keytool -genkeypair -v
#                            -keystore ... -keyalg RSA -keysize 2048
#                            -validity 25000 -alias <key-alias>`)
#
#   RELEASE_STORE_PASSWORD   the password you set for the keystore.
#
#   RELEASE_KEY_ALIAS        the alias of the release key inside the
#                            keystore (e.g. "release").
#
#   RELEASE_KEY_PASSWORD     password for the specific key — usually
#                            the same as the keystore password unless
#                            you split them.
#
#   APP_SENTRY_DSN           Sentry → Settings → Projects → [project]
#                            → Client Keys (DSN).
#                            Looks like `https://<key>@o<org>.ingest
#                            .sentry.io/<project>`.
#
#   SENTRY_AUTH_TOKEN        Sentry → Settings → API → Auth Tokens.
#                            Scopes required: project:releases +
#                            project:write (so the uploadSentry
#                            ProguardMappingsRelease task does not
#                            401).
#
# When this file is missing, the build falls back to the debug
# signing config (Sentry upload no-ops). Real values MUST be in
# place BEFORE the production release pipeline ships to Play.
# DO NOT commit this file — it's in .gitignore.

# Path to the release keystore (relative to repo root; not committed).
RELEASE_STORE_FILE=path/to/your-release.jks

RELEASE_STORE_PASSWORD=
RELEASE_KEY_ALIAS=release
RELEASE_KEY_PASSWORD=

# Sentry DSN.
APP_SENTRY_DSN=

# Sentry auth token (Settings → API → Auth Tokens).
SENTRY_AUTH_TOKEN=
