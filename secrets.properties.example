# secrets.properties — REAL API endpoints
#
# Place at the repo root as `secrets.properties` (gitignored — see the
# project's .gitignore). Values are encrypted at build time with
# AES-256-GCM (random per-build key) and embedded in the APK as
# `com.streamify.app.security.EncryptedConstants`. Decoded at runtime
# by `RuntimeStringProvider` / `RequestSigner`.
#
# When this file is missing, `app/build.gradle.kts` falls back to
# `https://learngermanwith.fun` for all URLs — which is a placeholder
# domain that returns nothing. Production builds MUST drop a copy of
# this file (with real values) into the build environment before
# `:app:assembleRelease`. DO NOT commit this file.

# Your backend base URL (typically ends with `/api`).
API_BASE_URL=https://api.your-domain.com/api

# Admin config endpoint (GET /api/config).
API_CONFIG_URL=https://api.your-domain.com/config

# Update URL (used for manual version-check re-direct).
UPDATE_URL=https://api.your-domain.com/update

# Telegram channel link (drawer → Join Us).
TELEGRAM_LINK=https://t.me/your-channel

# Phase 7 · Step 7.7 — HMAC-SHA256 signing secret consumed by
# RequestSigner. Generate with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(64))"
# and rotate at least quarterly. Empty string disables request
# signing (debug builds without this file). Encrypted at build
# time by the :app:encryptSecrets Gradle task; live in memory only.
SIGNING_SECRET=
