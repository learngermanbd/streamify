# secrets.properties — REAL API endpoints.
#
# Place at the repo root as `secrets.properties` (gitignored). Values
# are encrypted at build time with AES-256-GCM (random per-build key)
# and embedded in the APK as `com.streamify.app.security.EncryptedConstants`.
# Decoded at runtime by `RuntimeStringProvider` / `RequestSigner`.
#
# When this file is missing, `app/build.gradle.kts` falls back to
# `https://learngermanwith.fun` for all URLs — which only resolves
# correctly if you've deployed the backend at that exact host AND
# rotated the cert pin (see network_security_config.xml + SSLPinner.kt).
#
# IMPORTANT: the three URL fields below MUST use the same host(s) that
# the cert pin set covers, otherwise OkHttp will fail the TLS handshake
# with `CertificatePinnerException`.  Audiences / port changes require
# updating both `network_security_config.xml` (pin-set) AND
# `SSLPinner.kt` (PINS map) AND this file in lock-step.
#
# Production builds MUST drop a copy of this file into the build
# environment before `:app:assembleRelease`.  DO NOT commit it.

# Backend base URL. The app-side paths in ApiService.PATH_*
# (PATH_EVENTS="/api/events", PATH_CHANNELS="/api/channels", etc.) already
# include the /api prefix; ApiClient.joinUrl concatenates but does NOT de-dup.
# Keep this URL BARE (NO trailing /api) so the resulting URLs resolve to
# https://learngermanwith.fun/api/<resource> -- NOT
# https://learngermanwith.fun/api/api/<resource> (which would 404).
API_BASE_URL=https://learngermanwith.fun

# Admin config endpoint (GET /api/config).
API_CONFIG_URL=https://learngermanwith.fun/api/config

# Update URL (used for manual version-check re-direct).
UPDATE_URL=https://learngermanwith.fun/update

# Telegram channel link (drawer → Join Us).
TELEGRAM_LINK=https://t.me/learngermanbd

# Phase 7 · Step 7.7 — HMAC-SHA256 signing secret consumed by
# RequestSigner. Generate with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(64))"
# and rotate at least quarterly. Empty string disables request
# signing (debug builds without this file). Encrypted at build
# time by the :app:encryptSecrets Gradle task; live in memory only.
SIGNING_SECRET=
