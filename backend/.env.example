[TEMPLATE]
# SportStream Admin Backend environment variables
# Copy this file to .env and edit before running.
#
# DO NOT COMMIT .env it contains DATABASE_URL + JWT_SECRET for prod.

# --- Server ---
# Streamsify backend listens here.  Must match the port the Android
# fleet will hit (see SETUP.txt, secrets.properties.example, and the
# connectivity probe: `node backend/scripts/connectivity-check.js`).
# 4000 matches the SETUP.txt guidance; flip to 3000 only if you
# change the URL chain on every consumer in lock-step.
PORT=4000
NODE_ENV=development

# --- Database (Supabase Postgres pooler in prod; local Postgres for dev) ---
# 1. Local dev Postgres running on your workstation:
#    DATABASE_URL="postgresql://sportstream:sportstream@localhost:5432/sportstream_dev"
# 2. Supabase prod use the *pooler* URL (port 6543 not the direct
#    5432) so serverless / PgBouncer reconnects don't trigger SNI
#    handshake errors during high churn:
#    DATABASE_URL="postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres"
# If this is missing the backend still BOOTS but throws
#   [pg] Missing DATABASE_URL or DB_HOST/DB_USER/DB_PASSWORD env vars
# the first time any request hits the database.

# --- JWT ---
# Rotate JWT_SECRET for any non-dev environment.
JWT_SECRET="dev-not-secret-change-me"
# Must be different from JWT_SECRET in production.
JWT_REFRESH_SECRET="dev-refresh-secret-change-me"
JWT_ACCESS_EXP="15m"
JWT_REFRESH_EXP="7d"

# --- CORS ---
# Browsers for the web admin + Android intent scheme for the admin app.
ADMIN_WEB_ORIGIN="http://localhost:5173"
ADMIN_ANDROID_ORIGIN="app://com.sportstream.admin"

# --- FCM (lands in Step 8.4-8.18) ---
# Path to firebase-service-account.json (NOT committed).
FCM_SERVICE_ACCOUNT_JSON=""
FCM_DEFAULT_TOPIC="all_users"
