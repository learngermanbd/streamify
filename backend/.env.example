# SportStream Admin Backend \u2014 environment variables
# Copy this file to .env and edit before running.
#
# DO NOT COMMIT .env \u2014 it contains DATABASE_URL + JWT_SECRET for prod.

# --- Server ---
PORT=3000
NODE_ENV=development

# --- Database (Supabase Postgres in prod; SQLite for local dev) ---
DATABASE_URL="postgresql://user:password@localhost:5432/sportstream_dev"

# --- JWT ---
# Rotate JWT_SECRET for any non-dev environment.
JWT_SECRET="dev-not-secret-change-me"
# Must be different from JWT_SECRET in production.
JWT_REFRESH_SECRET="dev-refresh-secret-change-me"
JWT_ACCESS_EXP="15m"
JWT_REFRESH_EXP="7d"

# --- CORS ---
# Browsers for the web admin + Android intent scheme for the admin app.
ADMIN_WEB_ORIGIN="http://localhost:5173"
ADMIN_ANDROID_ORIGIN="app://com.sportstream.admin"

# --- FCM (lands in Step 8.4-8.18) ---
# Path to firebase-service-account.json (NOT committed).
FCM_SERVICE_ACCOUNT_JSON=""
FCM_DEFAULT_TOPIC="all_users"
