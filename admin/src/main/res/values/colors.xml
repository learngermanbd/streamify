<?xml version="1.0" encoding="utf-8"?>
<!--
    Phase 8 \u00b7 Step 8.13 \u2014 SportStream Admin palette.

    Orange (#F59E0B) primary instead of the user app's cyan (#1CCBD4) so
    admins immediately know they're in the admin app, not the user app.
    Same dark-glass surface family as :app to keep visual continuity.
-->
<resources>
    <!-- Brand: orange instead of cyan -->
    <color name="primary">#F59E0B</color>
    <color name="primary_dark">#B97506</color>
    <color name="secondary">#131931</color>

    <!-- Dark surface family -->
    <color name="admin_bg">#0A0F1A</color>
    <color name="card_bg">#121A27</color>
    <color name="border_default">#1E2D45</color>

    <!-- Text -->
    <color name="admin_text">#E0E6ED</color>
    <color name="admin_text_muted">#8899AA</color>

    <!-- Glass fills (orange-tinted, mirrors :app's cyan ones) -->
    <color name="glass_primary">#14F59E0B</color>
    <color name="glass_primary_border">#26F59E0B</color>

    <!-- Semantic accents -->
    <color name="live_red">#EF4444</color>
    <color name="success_green">#22C55E</color>
    <color name="warning_orange">#F59E0B</color>
</resources>
