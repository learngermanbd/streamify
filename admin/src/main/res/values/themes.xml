<?xml version="1.0" encoding="utf-8"?>
<!--
    Phase 8 \u00b7 Step 8.13 \u2014 SportStream Admin themes.

    Same parent as :app (Material3.DayNight.NoActionBar) but orange accents
    instead of cyan. Edge-to-edge transparent system bars, dark window bg.
-->
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.StreamifyAdmin" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/secondary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorAccent">@color/primary</item>

        <item name="android:colorBackground">@color/card_bg</item>
        <item name="android:windowBackground">@color/admin_bg</item>
        <item name="android:textColor">@color/admin_text</item>
        <item name="android:textColorPrimary">@color/admin_text</item>
        <item name="android:textColorSecondary">@color/admin_text_muted</item>

        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">false</item>
    </style>

    <style name="Theme.StreamifyAdmin.NoActionBar" parent="Theme.StreamifyAdmin">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <!-- Empty dot-inheritance anchors -->
    <style name="SportStreamAdmin" />
    <style name="SportStreamAdmin.GlassCard">
        <item name="cardBackgroundColor">@color/glass_primary</item>
        <item name="strokeColor">@color/glass_primary_border</item>
        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">12dp</item>
    </style>

</resources>
