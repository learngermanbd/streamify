<?xml version="1.0" encoding="utf-8"?>
<!--
    Phase 8 \u00b7 Step 8.13 \u2014 Admin glass card background.
    Same shape pattern as :app's bg_glass_card but tinted orange:
    12 dp corners, 8% primary fill, 1 dp stroke.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/glass_primary" />
    <stroke
        android:width="1dp"
        android:color="@color/glass_primary_border" />
    <corners android:radius="12dp" />
</shape>
