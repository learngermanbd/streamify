<?xml version="1.0" encoding="utf-8"?>
<!--
    Phase 3 · Step 3.3 — LIVE badge pulse animation.

    1.00 -> 1.06 -> 1.00 reverse infinite, ~800 ms each leg. Applied to
    the LIVE badge TextView in EventAdapter.onBindViewHolder when
    event.isLive == true. Pulse stays subtle (6 %) so it reads as a
    breathing dot, not a marquee.
-->
<set xmlns:android="http://schemas.android.com/apk/res/android"
    android:fillAfter="false"
    android:fillBefore="true"
    android:interpolator="@android:anim/accelerate_decelerate_interpolator"
    android:shareInterpolator="true">

    <scale
        android:duration="800"
        android:fromXScale="1.0"
        android:fromYScale="1.0"
        android:pivotX="50%"
        android:pivotY="50%"
        android:repeatCount="infinite"
        android:repeatMode="reverse"
        android:toXScale="1.06"
        android:toYScale="1.06" />
</set>
