<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
      Night-qualified tokens for Sportzfy dark glass UI.
      The app is dark-first so night and day share the same
      surface tokens — this file exists for DayNight compatibility.
    -->

    <!-- ── Brand ── -->
    <color name="primary">#00E676</color>
    <color name="primary_dark">#00C853</color>
    <color name="secondary">#16213E</color>
    <color name="on_primary">#0A0F1A</color>

    <!-- ── Surfaces ── -->
    <color name="dark_bg">#0D0D1A</color>
    <color name="card_bg">#1A1A2E</color>
    <color name="border_default">#2A2A3E</color>

    <!-- ── Text ── -->
    <color name="text">#F0F0F0</color>
    <color name="text_muted">#7B8CA0</color>

    <!-- ── Status ── -->
    <color name="live_red">#FF1744</color>
    <color name="success_green">#00E676</color>
    <color name="warning_orange">#FFB300</color>

    <!-- ── Glass overlays ── -->
    <color name="glass_primary">#1A00E676</color>
