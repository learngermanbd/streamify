<?xml version="1.0" encoding="utf-8"?>
<!--
    Phase 3 · Step 3.2 → Phase 6 · Step 6.4 — Settings tab body.

    Step 6.4 fills the placeholder that Stepm 5.5 (Drawer) + 5.6
    (Toolbar) wrapped with a real Settings form. Layout hosts the
    THEME picker (System / Light / Dark) wired to
    [com.streamify.app.data.prefs.ThemePrefs]. Future settings rows
    (Playback defaults, Notification preferences, etc.) append below
    the theme-help-text chain anchor by adding more ConstraintLayout
    rows.

    Uses NestedScrollView so a small device has room to scroll the
    full Settings sheet without clipping.
-->
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_bg"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:paddingVertical="32dp">

        <TextView
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/poppins_regular"
            android:letterSpacing="0.18"
            android:text="@string/fragment_settings_title"
            android:textColor="@color/primary"
            android:textSize="22sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:alpha="0.85"
            android:fontFamily="@font/poppins_regular"
            android:letterSpacing="0.04"
            android:text="@string/fragment_settings_subtitle"
            android:textColor="@color/text_muted"
            android:textSize="14sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/title" />

        <!--
            APPEARANCE section header \u2014 pill style to match the Favorites
            fragment's favoriteSectionHeader treatment.
        -->
        <TextView
            android:id="@+id/themeSectionHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="36dp"
            android:fontFamily="@font/poppins_regular"
            android:letterSpacing="0.22"
            android:paddingHorizontal="14dp"
            android:paddingVertical="6dp"
            android:text="@string/fragment_settings_appearance_section"
            android:textColor="@color/text"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/subtitle" />

        <!--
            Theme picker \u2014 3-chip ChipGroup with singleSelection=true.
            SettingsFragment wires each chip's onClickListener to
            ThemePrefs + AppCompatDelegate.setDefaultNightMode. The
            ChipGroup's singleSelection handles auto-uncheck-of-the-
            others interally; we don't need a setOnCheckedStateChangeListener.
        -->
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/themeChips"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:chipSpacingHorizontal="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/themeSectionHeader"
            app:singleLine="true"
            app:singleSelection="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/themeSystemChip"
                style="@style/Widget.Material3.Chip.Filter"
                android:checkable="true"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/theme_picker_system" />

            <com.google.android.material.chip.Chip
                android:id="@+id/themeLightChip"
                style="@style/Widget.Material3.Chip.Filter"
                android:checkable="true"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/theme_picker_light" />

            <com.google.android.material.chip.Chip
                android:id="@+id/themeDarkChip"
                style="@style/Widget.Material3.Chip.Filter"
                android:checkable="true"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/theme_picker_dark" />
        </com.google.android.material.chip.ChipGroup>

        <TextView
            android:id="@+id/themeHelpText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:alpha="0.75"
            android:fontFamily="@font/poppins_regular"
            android:letterSpacing="0.04"
            android:text="@string/fragment_settings_theme_hint"
            android:textColor="@color/text_muted"
            android:textSize="12sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/themeChips" />

        <!--
            App version footer \u2014 reflects packageManager versionName via
            SettingsFragment.onViewCreated's PackageInfo lookup. Sits at
            the bottom of the scrollable region so future settings rows
            don't crowd it.
        -->
        <TextView
            android:id="@+id/versionText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:alpha="0.55"
            android:fontFamily="@font/poppins_regular"
            android:letterSpacing="0.08"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/themeHelpText"
            tools:text="SportStream v1.0.0 (Phase 6 \u00b7 Step 6.4)" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>
