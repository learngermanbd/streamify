<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="80dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/poppins_regular"
            android:text="HEADERS &amp; CONFIGURATION"
            android:textColor="@color/text_muted"
            android:textSize="12sp"
            android:textStyle="bold" />

        <!-- Cookie field -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/headerCookieLayout"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Cookie"
            app:boxStrokeColor="@color/primary"
            app:endIconDrawable="@drawable/ic_paste"
            app:endIconMode="custom"
            app:hintTextColor="@color/text_muted">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/headerCookieInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_regular"
                android:imeOptions="actionNext"
                android:inputType="text"
                android:maxLines="2"
                android:textColor="@color/text"
                android:textSize="12sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Referer field -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/headerRefererLayout"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="Referer"
            app:boxStrokeColor="@color/primary"
            app:endIconDrawable="@drawable/ic_paste"
            app:endIconMode="custom"
            app:hintTextColor="@color/text_muted">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/headerRefererInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_regular"
                android:imeOptions="actionNext"
                android:inputType="textUri"
                android:maxLines="2"
                android:textColor="@color/text"
                android:textSize="12sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Origin field -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/headerOriginLayout"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="Origin"
            app:boxStrokeColor="@color/primary"
            app:endIconDrawable="@drawable/ic_paste"
            app:endIconMode="custom"
            app:hintTextColor="@color/text_muted">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/headerOriginInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_regular"
                android:imeOptions="actionDone"
                android:inputType="textUri"
                android:maxLines="2"
                android:textColor="@color/text"
                android:textSize="12sp" />
        </com.google.android.material.textfield.TextInputLayout>

    </LinearLayout>
</ScrollView>
