<?xml version="1.0" encoding="utf-8"?>
<!--
    Phase 5 · Step 5.6 — Channel result row inside the Search list.
    Stripped of the grid card art from view_item_channel.xml so the
    search row reads as a tile instead of a card.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_glass_card"
    android:padding="14dp"
    android:layout_marginHorizontal="6dp"
    android:layout_marginVertical="4dp">

    <TextView
        android:id="@+id/searchChannelName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:fontFamily="@font/poppins_regular"
        android:maxLines="1"
        android:ellipsize="end"
        android:textColor="@color/text"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="Sky Sports Football HD" />

    <TextView
        android:id="@+id/searchChannelCategory"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:fontFamily="@font/poppins_regular"
        android:textColor="@color/text_muted"
        android:textSize="12sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/searchChannelName"
        tools:text="Sports" />

</androidx.constraintlayout.widget.ConstraintLayout>
