<?xml version="1.0" encoding="utf-8"?>
<!--
    Sportzfy Player — matches the original Sportzfy APK player UI.

    Layout:
    - Top bar: Back arrow | Title (marquee) | Quality button
    - Links bar: horizontal stream source chips
    - Center: single play/pause button (no rewind/forward)
    - Bottom: position | thin seek bar | duration | fullscreen | lock
    - All overlays are semi-transparent and auto-hide on tap

    Color: green accent (#00E676) on seek bar and active elements.
    Gesture controls: swipe left=brightness, swipe right=volume (handled by SwipeGestureDetector).
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/playerRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <!-- Media3 Player host. useController=false — all controls are custom. -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/playerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@android:color/black"
        app:resize_mode="fit"
        app:use_controller="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Lock dim overlay — shown when controls are locked -->
    <View
        android:id="@+id/lockDimOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/lock_dim"
        android:clickable="true"
        android:focusable="false"
        android:importantForAccessibility="yes"
        android:contentDescription="@string/player_unlock_desc"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!--
        Top bar — Back | Title (marquee) | Quality.
        Minimal like original Sportzfy: only essential controls.
    -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#66000000"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="4dp"
        android:paddingVertical="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBack"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:contentDescription="@string/player_top_back"
            app:icon="@android:drawable/ic_menu_revert"
            app:iconTint="@color/text" />

        <TextView
            android:id="@+id/titleText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginHorizontal="6dp"
            android:ellipsize="marquee"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:fontFamily="@font/poppins_regular"
            android:marqueeRepeatLimit="marquee_forever"
            android:singleLine="true"
            android:textColor="@color/text"
            android:textSize="13sp"
            android:textStyle="bold"
            tools:text="Live: Manchester United vs Liverpool" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnQuality"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:contentDescription="@string/player_quality_title"
            app:icon="@android:drawable/ic_menu_view"
            app:iconTint="@color/text" />
    </LinearLayout>

    <!--
        Links bar — horizontal stream source chips (Server 1, Server 2, etc.)
    -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/linksBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#44000000"
        android:clipToPadding="false"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        android:paddingVertical="3dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        tools:itemCount="3"
        tools:listitem="@layout/view_player_link_chip" />

    <!--
        Center — single large play/pause button.
        Original Sportzfy shows ONLY play/pause in the center.
    -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnPlayPause"
        style="@style/Widget.Material3.Button.IconButton"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:contentDescription="@string/player_controls_play"
        app:icon="@android:drawable/ic_media_play"
        app:iconSize="36dp"
        app:iconTint="@color/primary"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!--
        Bottom bar — position | seek bar | duration | fullscreen | lock.
        Thin green seek bar matching Sportzfy style.
    -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#66000000"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="10dp"
        android:paddingVertical="6dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/positionText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/poppins_regular"
            android:gravity="end"
            android:singleLine="true"
            android:textColor="@color/text"
            android:textSize="11sp"
            tools:text="00:00" />

        <SeekBar
            android:id="@+id/seekBar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginHorizontal="8dp"
            android:max="1000"
            android:progressDrawable="@drawable/player_seekbar_progress"
            android:thumb="@drawable/player_seekbar_thumb" />

        <TextView
            android:id="@+id/durationText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/poppins_regular"
            android:gravity="start"
            android:singleLine="true"
            android:textColor="@color/text"
            android:textSize="11sp"
            tools:text="00:00" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFullscreen"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="6dp"
            android:contentDescription="@string/player_fullscreen_enter"
            app:icon="@android:drawable/ic_menu_view"
            app:iconSize="20dp"
            app:iconTint="@color/text" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLock"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="2dp"
            android:contentDescription="@string/player_lock_desc"
            app:icon="@android:drawable/ic_lock_lock"
            app:iconSize="20dp"
            app:iconTint="@color/text" />
    </LinearLayout>

    <!-- Loading spinner — centered while buffering -->
    <com.google.android.material.progressindicator.CircularProgressIndicator
        android:id="@+id/loadingIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:indeterminate="true"
        android:visibility="gone"
        app:indicatorColor="@color/primary"
        app:indicatorSize="48dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:trackThickness="3dp" />

    <!-- Error state -->
    <TextView
        android:id="@+id/errorText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:fontFamily="@font/poppins_regular"
        android:gravity="center"
        android:paddingHorizontal="32dp"
        android:textColor="@color/live_red"
        android:textSize="14sp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="Couldn't load channel" />

    <!-- Gesture feedback overlay (brightness/volume/seek indicator) -->
    <include
        android:id="@+id/swipeGestureOverlay"
        layout="@layout/layout_swipe_gesture"
        android:layout_width="200dp"
        android:layout_height="80dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
