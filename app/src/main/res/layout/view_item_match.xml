<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:background="@drawable/bg_match_card_sportzfy">

    <!-- Top accent line -->
    <View
        android:id="@+id/accentLine"
        android:layout_width="0dp"
        android:layout_height="2dp"
        android:background="@drawable/bg_live_dot"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Top row: league info + LIVE badge -->
    <TextView
        android:id="@+id/leagueInfo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="8dp"
        android:ellipsize="end"
        android:fontFamily="@font/poppins_regular"
        android:maxLines="1"
        android:paddingHorizontal="12dp"
        android:textColor="@color/text_muted"
        android:textSize="9sp"
        app:layout_constraintEnd_toStartOf="@id/liveBadge"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/accentLine"
        tools:text="🟢 Football · Premier League 25/26" />

    <TextView
        android:id="@+id/liveBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="12dp"
        android:background="@drawable/bg_live_badge"
        android:fontFamily="@font/poppins_regular"
        android:letterSpacing="0.10"
        android:paddingHorizontal="8dp"
        android:paddingVertical="2dp"
        android:text="@string/view_item_match_live"
        android:textColor="@color/white"
        android:textSize="8sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/leagueInfo"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/leagueInfo" />

    <!-- Teams row -->
    <ImageView
        android:id="@+id/teamALogo"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginStart="12dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_team_logo_placeholder"
        android:contentDescription="@string/view_item_match_team_a_desc"
        android:scaleType="centerCrop"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/leagueInfo" />

    <TextView
        android:id="@+id/teamAName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:ellipsize="end"
        android:fontFamily="@font/poppins_regular"
        android:gravity="center"
        android:maxLines="1"
        android:textColor="@color/text"
        android:textSize="9sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@id/vsText"
        app:layout_constraintStart_toStartOf="@id/teamALogo"
        app:layout_constraintTop_toBottomOf="@id/teamALogo"
        tools:text="Crystal Palace" />

    <LinearLayout
        android:id="@+id/vsText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="@id/teamALogo"
        app:layout_constraintEnd_toStartOf="@id/teamBLogo"
        app:layout_constraintStart_toEndOf="@id/teamALogo"
        app:layout_constraintTop_toTopOf="@id/teamALogo">

        <TextView
            android:id="@+id/scoreText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/poppins_regular"
            android:textColor="@color/text"
            android:textSize="14sp"
            android:textStyle="bold"
            tools:text="0 — 2" />

        <TextView
            android:id="@+id/vsLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_status_pill_active"
            android:fontFamily="@font/poppins_regular"
            android:paddingHorizontal="6dp"
            android:paddingVertical="1dp"
            android:text="@string/view_item_match_vs"
            android:textColor="@color/primary"
            android:textSize="9sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ImageView
        android:id="@+id/teamBLogo"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_team_logo_placeholder"
        android:contentDescription="@string/view_item_match_team_b_desc"
        android:scaleType="centerCrop"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/leagueInfo" />

    <TextView
        android:id="@+id/teamBName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:ellipsize="end"
        android:fontFamily="@font/poppins_regular"
        android:gravity="center"
        android:maxLines="1"
        android:textColor="@color/text"
        android:textSize="9sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="@id/teamBLogo"
        app:layout_constraintStart_toEndOf="@id/vsText"
        app:layout_constraintTop_toBottomOf="@id/teamBLogo"
        tools:text="Liverpool" />

    <!-- Bottom row: time + watch button -->
    <View
        android:id="@+id/bottomDivider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginTop="8dp"
        android:background="@color/border_default"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/teamBName" />

    <TextView
        android:id="@+id/timeText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:fontFamily="@font/poppins_regular"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp"
        android:textColor="@color/text_muted"
        android:textSize="9sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/watchBtn"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/bottomDivider"
        tools:text="67' · 2nd Half" />

    <TextView
        android:id="@+id/watchBtn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="12dp"
        android:fontFamily="@font/poppins_regular"
        android:paddingVertical="6dp"
        android:text="▶ Watch"
        android:textColor="@color/primary"
        android:textSize="9sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/bottomDivider" />

</androidx.constraintlayout.widget.ConstraintLayout>
