<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:background="@drawable/bg_match_card_sportzfy">

    <!-- Top accent line -->
    <View
        android:id="@+id/accentLine"
        android:layout_width="0dp"
        android:layout_height="2dp"
        android:background="@drawable/bg_live_dot"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Row 1: Tournament/Cup info (left) + Countdown/LIVE badge (right) -->
    <TextView
        android:id="@+id/tournamentInfo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp"
        android:ellipsize="end"
        android:fontFamily="@font/poppins_regular"
        android:maxLines="1"
        android:paddingHorizontal="12dp"
        android:textColor="@color/text_muted"
        android:textSize="9sp"
        app:layout_constraintEnd_toStartOf="@id/timeBadge"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/accentLine"
        tools:text="🏆 Cup • Round 2" />

    <TextView
        android:id="@+id/timeBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="12dp"
        android:fontFamily="@font/poppins_regular"
        android:letterSpacing="0.05"
        android:paddingHorizontal="6dp"
        android:paddingVertical="2dp"
        android:textColor="@color/text_muted"
        android:textSize="8sp"
        app:layout_constraintBottom_toBottomOf="@id/tournamentInfo"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tournamentInfo"
        tools:text="🕒 07:49:16" />

    <TextView
        android:id="@+id/liveBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="12dp"
        android:background="@drawable/bg_live_badge"
        android:fontFamily="@font/poppins_regular"
        android:letterSpacing="0.10"
        android:paddingHorizontal="8dp"
        android:paddingVertical="2dp"
        android:text="@string/view_item_match_live"
        android:textColor="@color/white"
        android:textSize="8sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/tournamentInfo"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tournamentInfo" />

    <!-- Row 2: Sport category + League title (e.g. "Football ll World Cup 2026") -->
    <TextView
        android:id="@+id/leagueInfo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:ellipsize="end"
        android:fontFamily="@font/poppins_regular"
        android:maxLines="1"
        android:paddingHorizontal="12dp"
        android:textColor="@color/text_muted"
        android:textSize="8sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tournamentInfo"
        tools:text="Football ll World Cup 2026" />

    <!-- Teams row: (flag) Team A  VS  Team B (flag) -->
    <TextView
        android:id="@+id/teamAFlag"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="8dp"
        android:fontFamily="@font/poppins_regular"
        android:textSize="16sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/leagueInfo"
        tools:text="🇦🇺" />

    <TextView
        android:id="@+id/teamAName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:layout_marginTop="10dp"
        android:ellipsize="end"
        android:fontFamily="@font/poppins_regular"
        android:gravity="end"
        android:maxLines="1"
        android:textColor="@color/text"
        android:textSize="10sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@id/vsLabel"
        app:layout_constraintStart_toEndOf="@id/teamAFlag"
        app:layout_constraintTop_toBottomOf="@id/leagueInfo"
        tools:text="New Zealand" />

    <TextView
        android:id="@+id/vsLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_status_pill_active"
        android:fontFamily="@font/poppins_regular"
        android:paddingHorizontal="10dp"
        android:paddingVertical="3dp"
        android:text="@string/view_item_match_vs"
        android:textColor="@color/primary"
        android:textSize="10sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/teamAName"
        app:layout_constraintEnd_toStartOf="@id/teamBName"
        app:layout_constraintStart_toEndOf="@id/teamAName"
        app:layout_constraintTop_toTopOf="@id/teamAName" />

    <TextView
        android:id="@+id/teamBName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginEnd="4dp"
        android:layout_marginTop="10dp"
        android:ellipsize="end"
        android:fontFamily="@font/poppins_regular"
        android:gravity="start"
        android:maxLines="1"
        android:textColor="@color/text"
        android:textSize="10sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@id/teamBFlag"
        app:layout_constraintStart_toEndOf="@id/vsLabel"
        app:layout_constraintTop_toBottomOf="@id/leagueInfo"
        tools:text="Egypt" />

    <TextView
        android:id="@+id/teamBFlag"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="8dp"
        android:fontFamily="@font/poppins_regular"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/leagueInfo"
        tools:text="🇪🇬" />

    <!-- Hidden views kept for backward compatibility with EventAdapter Glide calls -->
    <ImageView
        android:id="@+id/teamALogo"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/teamBLogo"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Hidden compatibility views for EventAdapter binding references -->
    <LinearLayout
        android:id="@+id/vsText"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/scoreText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <TextView
        android:id="@+id/timeText"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/watchBtn"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/bottomDivider"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
