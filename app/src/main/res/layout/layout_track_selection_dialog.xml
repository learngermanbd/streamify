<?xml version="1.0" encoding="utf-8"?>
<!--
    Step 4.5 — TrackSelectionDialog content layout.

    A BottomSheetDialog hosts this view; the dialog itself is in
    `TrackSelectionDialogFragment.kt` so it can be re-shown from
    BindIndicator-style callbacks in PlayerActivity.

    For v1 we expose ONLY the subtitle track group. The video + audio
    sections are deferred to Step 4.7 polish (the strict plan does call
    for "radio buttons for Video, Audio, and Subtitle tracks with the
    current selection highlighted" but bundling them all into one dialog
    in Step 4.5 swells the surface area; the quality selector already
    handles the video side via VideoQualityManager).
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/trackSelectionRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/card_bg"
    android:paddingHorizontal="20dp"
    android:paddingVertical="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="12dp">

        <TextView
            android:id="@+id/trackSelectionTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="@font/poppins_regular"
            android:text="@string/player_track_selection_title"
            android:textColor="@color/text"
            android:textSize="16sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/trackSelectionCloseBtn"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/player_track_selection_close_desc"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:tint="@color/text_muted" />
    </LinearLayout>

    <!-- Empty state (shown when the player has no subtitle tracks). -->
    <TextView
        android:id="@+id/trackSelectionEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="12dp"
        android:text="@string/player_track_selection_empty"
        android:textColor="@color/text_muted"
        android:textSize="13sp"
        android:visibility="gone"
        tools:visibility="visible" />

    <!-- Section header. -->
    <TextView
        android:id="@+id/trackSelectionSubtitleHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="@font/poppins_regular"
        android:paddingTop="6dp"
        android:paddingBottom="8dp"
        android:text="@string/player_track_selection_section_subtitle"
        android:textColor="@color/text_muted"
        android:textSize="12sp"
        android:textStyle="bold" />

    <RadioGroup
        android:id="@+id/trackSelectionSubtitleGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="12dp" />

    <!-- Bottom close area (alternatively tap tracking sheet outside). -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:orientation="horizontal"
        android:paddingTop="8dp">

        <Button
            android:id="@+id/trackSelectionDoneBtn"
            style="?attr/borderlessButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/poppins_regular"
            android:text="@string/player_track_selection_done"
            android:textColor="@color/primary" />
    </LinearLayout>
</LinearLayout>
