<?xml version="1.0" encoding="utf-8"?>
<!--
    Phase 3 · Step 3.5 — Highlights tab content.

    Top — section header ("HIGHLIGHTS" pill in primary).
    Body — RecyclerView with a vertical LinearLayoutManager; each row
    is a full-width view_item_highlight.xml 16:9 thumbnail card.
    Overlays — Material 3 CircularProgressIndicator (Loading) and a
    TextView empty-state. Both start gone; the fragment toggles.

    No chip filter yet — Highlights are raw chronological output from
    the backend. Search/filter lands in Step 5.6 (Toolbar debounced
    search against `highlights.title`).
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_bg">

    <!-- Section header. -->
    <TextView
        android:id="@+id/sectionTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:fontFamily="@font/poppins_regular"
        android:letterSpacing="0.18"
        android:paddingHorizontal="20dp"
        android:text="@string/fragment_highlights_header"
        android:textColor="@color/primary"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Highlights list — vertical, full-width, single column. -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/highlightsRv"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="14dp"
        android:clipToPadding="false"
        android:paddingTop="4dp"
        android:paddingBottom="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"            app:layout_constraintTop_toBottomOf="@id/sectionTitle"
            android:layoutAnimation="@anim/layout_anim_fall_down"
            tools:listitem="@layout/view_item_highlight"
            tools:itemCount="5" />

    <!-- Empty state overlay. -->
    <TextView
        android:id="@+id/emptyState"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:fontFamily="@font/poppins_regular"
        android:gravity="center"
        android:letterSpacing="0.06"
        android:paddingHorizontal="32dp"
        android:text="@string/fragment_highlights_empty"
        android:textColor="@color/text_muted"
        android:textSize="14sp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/highlightsRv"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/highlightsRv" />

    <!-- Loading overlay. -->
    <com.google.android.material.progressindicator.CircularProgressIndicator
        android:id="@+id/loadingIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:indeterminate="true"
        android:visibility="gone"
        app:indicatorColor="@color/primary"
        app:indicatorSize="40dp"
        app:layout_constraintBottom_toBottomOf="@id/highlightsRv"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/highlightsRv"
        app:layout_constraintVertical_bias="0.4"
        app:trackThickness="3dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
