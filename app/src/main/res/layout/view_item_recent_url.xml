<?xml version="1.0" encoding="utf-8"?>
<!--
    Phase 5 · Step 5.3 — RecyclerView row layout for the
    "Recently used network streams" list on the Network Stream screen.

    Layout: 44dp tinted icon  | URL TextView (ellipsized middle so the
    protocol/domain stays visible)               | format chip | remove
    IconButton. MaterialCardView is the glass-card row container so the
    swipe-to-delete affordance mounted at the fragment layer (Future
    Step 5.7 polish) drops on without a layout rewrite.
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="@color/glass_primary"
    app:cardCornerRadius="14dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/glass_primary_border"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="14dp"
        android:paddingVertical="12dp">

        <ImageView
            android:id="@+id/recentUrlIcon"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_team_logo_placeholder"
            android:contentDescription="@string/network_stream_icon_desc"
            android:padding="8dp"
            android:src="@android:drawable/ic_menu_send"
            app:tint="@color/primary"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/recentUrlText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            android:ellipsize="middle"
            android:fontFamily="@font/poppins_regular"
            android:maxLines="2"
            android:singleLine="false"
            android:textColor="@color/text"
            android:textSize="13sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/recentUrlFormatChip"
            app:layout_constraintStart_toEndOf="@id/recentUrlIcon"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="https://live.example.com/stream/team-a-vs-team-b/playlist.m3u8" />

        <com.google.android.material.chip.Chip
            android:id="@+id/recentUrlFormatChip"
            style="@style/Widget.Material3.Chip.Suggestion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            android:clickable="false"
            android:focusable="false"
            android:textColor="@color/text"
            app:chipMinHeight="28dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/recentUrlRemoveButton"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="HLS" />

        <ImageButton
            android:id="@+id/recentUrlRemoveButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/network_stream_recent_remove_desc"
            android:padding="6dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            app:tint="@color/text_muted"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
