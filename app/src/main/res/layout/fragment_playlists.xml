<?xml version="1.0" encoding="utf-8"?>
<!--
    Phase 5 · Step 5.2 — Playlists screen.

    Section header + RecyclerView (1 column of glass-card rows from
    view_item_playlist.xml) + FloatingActionButton anchored bottom-right
    for "Create playlist". Loading + empty-state follow the same
    pattern as FavoritesFragment so the two screens feel symmetric to
    the user.

    ItemTouchHelper swipe-to-delete is attached programmatically by
    PlaylistsFragment.onViewCreated (drives an undo Snackbar that
    re-inserts via the VM's create() with the original name).
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:id="@+id/playlistsSectionHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="16dp"
        android:fontFamily="@font/poppins_regular"
        android:letterSpacing="0.22"
        android:paddingHorizontal="14dp"
        android:paddingVertical="6dp"
        android:text="@string/fragment_playlists_title"
        android:textColor="@color/text"
        android:textSize="12sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/playlistsRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="96dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/playlistsSectionHeader"
        tools:listitem="@layout/view_item_playlist" />

    <com.google.android.material.progressindicator.CircularProgressIndicator
        android:id="@+id/playlistsLoadingIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:indeterminate="true"
        android:visibility="gone"
        app:indicatorColor="@color/primary"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/playlistsEmptyText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="40dp"
        android:alpha="0.85"
        android:fontFamily="@font/poppins_regular"
        android:gravity="center"
        android:letterSpacing="0.04"
        android:text="@string/playlists_empty"
        android:textColor="@color/text_muted"
        android:textSize="14sp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/playlistsFab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="20dp"
        android:contentDescription="@string/playlists_create_fab_desc"
        app:backgroundTint="@color/primary"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:srcCompat="@android:drawable/ic_input_add"
        app:tint="@color/dark_bg" />
</androidx.constraintlayout.widget.ConstraintLayout>
