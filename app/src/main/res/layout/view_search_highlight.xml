<?xml version="1.0" encoding="utf-8"?>
<!--
    Phase 5 · Step 5.6 — Highlight result row inside the Search list.
    Compact 16:9 thumbnail + title + meta below, mirroring the structure
    of view_item_highlight.xml but with smaller typography so the search
    surface stays scannable.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_glass_card"
    android:padding="10dp"
    android:layout_marginHorizontal="6dp"
    android:layout_marginVertical="4dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/searchHighlightThumbWrap"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintDimensionRatio="16:9"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/searchHighlightThumb"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_highlight_placeholder"
            android:scaleType="centerCrop"
            android:contentDescription="@string/view_item_highlight_default_title"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/searchHighlightDuration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="6dp"
            android:background="@drawable/bg_duration_pill"
            android:fontFamily="@font/poppins_regular"
            android:paddingHorizontal="6dp"
            android:paddingVertical="1dp"
            android:textColor="@color/text"
            android:textSize="11sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="02:34" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <TextView
        android:id="@+id/searchHighlightTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:fontFamily="@font/poppins_regular"
        android:maxLines="2"
        android:ellipsize="end"
        android:textColor="@color/text"
        android:textSize="13sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/searchHighlightThumbWrap"
        tools:text="Top 10 goals of the week" />

    <TextView
        android:id="@+id/searchHighlightMeta"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:fontFamily="@font/poppins_regular"
        android:maxLines="1"
        android:ellipsize="end"
        android:textColor="@color/text_muted"
        android:textSize="11sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/searchHighlightTitle"
        tools:text="12.4K views · 2 days ago" />

</androidx.constraintlayout.widget.ConstraintLayout>
