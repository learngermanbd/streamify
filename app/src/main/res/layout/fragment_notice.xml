<?xml version="1.0" encoding="utf-8"?>
<!--
    Phase 5 \u00b7 Step 5.5 v2 \u2014 Notice layout (multi-section + fallback).

    Three render states + retained chrome:

      \u2022 noticeRecycler       \u2014 ListMode (multi-section cards)
      \u2022 noticeBodyCard       \u2014 LegacyMode (single free-form string)
      \u2022 noticeEmptyState     \u2014 Empty (no notices anywhere)
      \u2022 noticeErrorCard      \u2014 UiState.Error
      \u2022 noticeProgress       \u2014 Loading / Idle overlay

    Persistence parity with v1: the header, FAB and progress overlay
    all stay visible on top of whichever surface is currently rendered
    so the user always has an escape hatch (refresh) and the screen
    never loses context (\"this is the Notice screen\").

    The RecyclerView is match_parent / 0dp so the FAB can stay
    anchored at the bottom-end regardless of scroll position.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_bg">

    <!-- Header (always visible) -->
    <TextView
        android:id="@+id/noticeHeaderTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="32dp"
        android:fontFamily="@font/poppins_regular"
        android:letterSpacing="0.18"
        android:text="@string/notice_v2_title"
        android:textColor="@color/primary"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/noticeHeaderSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="6dp"
        android:layout_marginEnd="24dp"
        android:alpha="0.85"
        android:fontFamily="@font/poppins_regular"
        android:text="@string/notice_v2_subtitle"
        android:textColor="@color/text_muted"
        android:textSize="13sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/noticeHeaderTitle" />

    <!-- v2 ListMode surface -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/noticeRecycler"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="96dp"
        android:clipToPadding="false"
        android:paddingTop="6dp"
        android:paddingBottom="0dp"
        android:scrollbars="none"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/noticeHeaderSubtitle"
        tools:listitem="@layout/view_notice_card" />

    <!-- v1 fallback: LegacyMode body card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/noticeBodyCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="96dp"
        android:visibility="gone"
        app:cardBackgroundColor="@color/card_bg"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/glass_primary_border"
        app:strokeWidth="1dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/noticeHeaderSubtitle">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fadeScrollbars="false"
            android:scrollbarStyle="outsideOverlay">

            <TextView
                android:id="@+id/noticeBodyText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_regular"
                android:lineSpacingExtra="6dp"
                android:padding="20dp"
                android:textColor="@color/text"
                android:textSize="15sp"
                tools:text="v1 fallback notice text" />
        </ScrollView>
    </com.google.android.material.card.MaterialCardView>

    <!-- Empty state -->
    <LinearLayout
        android:id="@+id/noticeEmptyState"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="40dp"
        android:layout_marginEnd="40dp"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:alpha="0.6"
            android:contentDescription="@null"
            android:src="@drawable/ic_notice" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:fontFamily="@font/poppins_regular"
            android:text="@string/notice_empty_title"
            android:textColor="@color/text"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:alpha="0.85"
            android:fontFamily="@font/poppins_regular"
            android:text="@string/notice_empty_subtitle"
            android:textColor="@color/text_muted"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- Loading -->
    <ProgressBar
        android:id="@+id/noticeProgress"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:indeterminateTint="@color/primary"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Error card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/noticeErrorCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:visibility="gone"
        app:cardBackgroundColor="@color/glass_red"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/live_red"
        app:strokeWidth="1dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_regular"
                android:text="@string/notice_error_title"
                android:textColor="@color/live_red"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/noticeErrorText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:alpha="0.85"
                android:fontFamily="@font/poppins_regular"
                android:textColor="@color/text"
                android:textSize="13sp"
                tools:text="Network unavailable" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/noticeRetryButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="@string/notice_error_retry"
                app:backgroundTint="@color/primary"
                app:cornerRadius="10dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- FAB refresh (always visible) -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/noticeRefreshFab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="24dp"
        android:text="@string/notice_refresh"
        android:textColor="@color/dark_bg"
        app:backgroundTint="@color/primary"
        app:icon="@drawable/ic_notice"
        app:iconTint="@color/dark_bg"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
