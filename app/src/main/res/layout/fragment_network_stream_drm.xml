<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="80dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/poppins_regular"
            android:text="DRM SETTINGS"
            android:textColor="@color/text_muted"
            android:textSize="12sp"
            android:textStyle="bold" />

        <!-- License URL field -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/drmLicenseUrlLayout"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="License URL"
            app:boxStrokeColor="@color/primary"
            app:endIconDrawable="@drawable/ic_paste"
            app:endIconMode="custom"
            app:hintTextColor="@color/text_muted">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/drmLicenseUrlInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_regular"
                android:imeOptions="actionDone"
                android:inputType="textUri"
                android:maxLines="2"
                android:textColor="@color/text"
                android:textSize="12sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Decryption + Scheme selectors -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/drmDecryptionLayout"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Decryption"
                app:boxStrokeColor="@color/primary"
                app:hintTextColor="@color/text_muted">

                <AutoCompleteTextView
                    android:id="@+id/drmDecryptionDropdown"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins_regular"
                    android:inputType="none"
                    android:text="Default"
                    android:textColor="@color/text"
                    android:textSize="12sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/drmSchemeLayout"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:hint="Scheme"
                app:boxStrokeColor="@color/primary"
                app:hintTextColor="@color/text_muted">

                <AutoCompleteTextView
                    android:id="@+id/drmSchemeDropdown"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins_regular"
                    android:inputType="none"
                    android:text="ClearKey"
                    android:textColor="@color/text"
                    android:textSize="12sp" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
