<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_bg"
    android:orientation="vertical"
    android:paddingHorizontal="16dp"
    android:paddingTop="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/poppins_regular"
        android:text="ENTER LIVE MEDIA STREAM URL"
        android:textColor="@color/text_muted"
        android:textSize="12sp"
        android:textStyle="bold" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/networkStreamUrlInputLayout"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:hint="@string/network_stream_url_hint"
        app:boxStrokeColor="@color/primary"
        app:endIconDrawable="@drawable/ic_paste"
        app:endIconMode="custom"
        app:hintTextColor="@color/text_muted">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/networkStreamUrlInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/poppins_regular"
            android:imeOptions="actionDone"
            android:inputType="textUri"
            android:maxLines="2"
            android:textColor="@color/text"
            android:textSize="14sp" />
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:fontFamily="@font/poppins_regular"
        android:text="QUICK CONFIG SELECTIONS:"
        android:textColor="@color/text_muted"
        android:textSize="12sp"
        android:textStyle="bold" />

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/networkStreamFormatChips"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:checkedChip="@id/networkStreamFormatChipAuto"
        app:chipSpacingHorizontal="8dp"
        app:selectionRequired="true"
        app:singleLine="true"
        app:singleSelection="true">

        <com.google.android.material.chip.Chip
            android:id="@+id/networkStreamFormatChipAuto"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checkable="true"
            android:checked="true"
            android:text="Decryption: Default" />

        <com.google.android.material.chip.Chip
            android:id="@+id/networkStreamFormatChipHls"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checkable="true"
            android:text="Scheme: ClearKey" />
    </com.google.android.material.chip.ChipGroup>

    <!-- Tip text -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_notice_bar"
        android:orientation="vertical"
        android:padding="10dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/poppins_regular"
            android:lineSpacingExtra="2dp"
            android:text="💡 Tip: Tap the 'Request Headers' tab above if your network source requires customized user-agent or security authorization cookie tokens."
            android:textColor="@color/text_muted"
            android:textSize="9sp" />
    </LinearLayout>

    <!-- Recent URLs section -->
    <TextView
        android:id="@+id/networkStreamRecentHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:fontFamily="@font/poppins_regular"
        android:text="@string/network_stream_recent_section"
        android:textColor="@color/text_muted"
        android:textSize="12sp"
        android:textStyle="bold" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/networkStreamRecentRecycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="6dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="80dp"
        tools:listitem="@layout/view_item_recent_url" />

    <TextView
        android:id="@+id/networkStreamEmptyText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:fontFamily="@font/poppins_regular"
        android:gravity="center"
        android:text="@string/network_stream_recent_empty"
        android:textColor="@color/text_muted"
        android:textSize="12sp"
        android:visibility="gone"
        tools:visibility="visible" />

</LinearLayout>
