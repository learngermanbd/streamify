<?xml version="1.0" encoding="utf-8"?>
<!--
    Phase 5 · Step 5.5 v2 — Notice card row used by NoticeAdapter.

    Card layout (top-to-bottom):
      • Section badge + priority chip + push-sourced dot
      • Title + body
      • Timestamp (relative)
      • Optional thumbnail (first IMAGE attachment)
      • Attachments strip (chips)

    The whole card is clickable; tapping issues an open url-equivalent
    deepLink if present, else no-op.
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/noticeCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="20dp"
    android:layout_marginEnd="20dp"
    android:layout_marginBottom="14dp"
    android:foreground="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="@color/card_bg"
    app:cardCornerRadius="14dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/glass_primary_border"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Badges row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/noticeCardSectionBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_regular"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:textColor="@color/dark_bg"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.18"
                tools:text="INFO" />

            <View
                android:id="@+id/noticeCardPriorityChip"
                android:layout_width="34dp"
                android:layout_height="14dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_notice_priority_urgent"
                android:visibility="gone" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <View
                android:id="@+id/noticeCardPushDot"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/bg_live_dot"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Title + body -->
        <TextView
            android:id="@+id/noticeCardTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:fontFamily="@font/poppins_regular"
            android:textColor="@color/text"
            android:textSize="15sp"
            android:textStyle="bold"
            tools:text="Server maintenance this Sunday" />

        <TextView
            android:id="@+id/noticeCardBody"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:alpha="0.92"
            android:fontFamily="@font/poppins_regular"
            android:lineSpacingExtra="3dp"
            android:textColor="@color/text"
            android:textSize="13sp"
            tools:text="Streams may be unavailable between 02:00 — 02:30 UTC. We apologise for any inconvenience." />

        <!-- Timestamp -->
        <TextView
            android:id="@+id/noticeCardTimestamp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:alpha="0.75"
            android:fontFamily="@font/poppins_regular"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            tools:text="3 hours ago" />

        <!-- Thumbnail (optional) -->
        <ImageView
            android:id="@+id/noticeCardThumbnail"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginTop="10dp"
            android:scaleType="centerCrop"
            android:contentDescription="@null"
            android:background="@color/secondary"
            android:visibility="gone" />

        <!-- Attachments strip -->
        <LinearLayout
            android:id="@+id/noticeCardAttachments"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal"
            android:visibility="gone" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
