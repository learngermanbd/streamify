<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/swipeRefresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/dark_bg"
        android:orientation="vertical">

        <!-- Dismissible Ad / Promo Banner -->
        <androidx.cardview.widget.CardView
            android:id="@+id/adBannerCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="10dp"
            android:layout_marginTop="6dp"
            app:cardBackgroundColor="#1A1A2E"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/poppins_regular"
                        android:text="🌐 Download Our Latest v20.0 to Play Quiz &amp; Earn 500$ From:⭐️\nhttps://thesportzfybd.com ⭐️"
                        android:textColor="#F0C040"
                        android:textSize="9sp" />

                    <ImageView
                        android:id="@+id/adBannerClose"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginStart="6dp"
                        android:contentDescription="Close banner"
                        android:padding="2dp"
                        android:src="@android:drawable/ic_menu_close_clear_cancel"
                        app:tint="@color/text_muted" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:autoLink="web"
                    android:fontFamily="@font/poppins_regular"
                    android:text="👉 Join our Official Facebook Group: https://www.facebook.com/thesportzfy"
                    android:textColor="#5B9DF0"
                    android:textSize="8sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Marquee Scrolling Notice -->
        <TextView
            android:id="@+id/noticeBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_notice_bar"
            android:layout_marginTop="4dp"
            android:ellipsize="marquee"
            android:focusable="true"
            android:fontFamily="@font/poppins_regular"
            android:marqueeRepeatLimit="marquee_forever"
            android:paddingHorizontal="14dp"
            android:paddingVertical="6dp"
            android:scrollHorizontally="true"
            android:singleLine="true"
            android:text="🔔 To Download Official Latest App. Don't get Scammed by fake apps!"
            android:textColor="#F0C040"
            android:textSize="9sp" />

        <!-- Circular Category Badges -->
        <HorizontalScrollView
            android:id="@+id/categoryBadgeScroll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipToPadding="false"
            android:overScrollMode="never"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/categoryBadges"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="10dp"
                android:paddingVertical="8dp">

                <!-- All -->
                <LinearLayout
                    android:id="@+id/badgeAll"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical">

                    <FrameLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp">

                        <TextView
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:background="@drawable/bg_category_badge_selected"
                            android:gravity="center"
                            android:text="⚡"
                            android:textSize="20sp" />

                        <TextView
                            android:id="@+id/badgeAllCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="top|end"
                            android:background="@drawable/bg_badge_counter"
                            android:fontFamily="@font/poppins_regular"
                            android:paddingHorizontal="4dp"
                            android:paddingVertical="0dp"
                            android:text="0"
                            android:textColor="@color/white"
                            android:textSize="7sp"
                            android:textStyle="bold"
                            android:visibility="gone" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:fontFamily="@font/poppins_regular"
                        android:text="All"
                        android:textColor="@color/primary"
                        android:textSize="8sp" />
                </LinearLayout>

                <!-- Cricket -->
                <LinearLayout
                    android:id="@+id/badgeCricket"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:gravity="center"
                    android:orientation="vertical">

                    <FrameLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp">

                        <TextView
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:background="@drawable/bg_category_badge"
                            android:gravity="center"
                            android:text="🏏"
                            android:textSize="20sp" />

                        <TextView
                            android:id="@+id/badgeCricketCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="top|end"
                            android:background="@drawable/bg_badge_counter"
                            android:fontFamily="@font/poppins_regular"
                            android:paddingHorizontal="4dp"
                            android:paddingVertical="0dp"
                            android:text="0"
                            android:textColor="@color/white"
                            android:textSize="7sp"
                            android:textStyle="bold"
                            android:visibility="gone" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:fontFamily="@font/poppins_regular"
                        android:text="Cricket"
                        android:textColor="@color/text_muted"
                        android:textSize="8sp" />
                </LinearLayout>

                <!-- Football -->
                <LinearLayout
                    android:id="@+id/badgeFootball"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:gravity="center"
                    android:orientation="vertical">

                    <FrameLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp">

                        <TextView
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:background="@drawable/bg_category_badge"
                            android:gravity="center"
                            android:text="⚽"
                            android:textSize="20sp" />

                        <TextView
                            android:id="@+id/badgeFootballCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="top|end"
                            android:background="@drawable/bg_badge_counter"
                            android:fontFamily="@font/poppins_regular"
                            android:paddingHorizontal="4dp"
                            android:paddingVertical="0dp"
                            android:text="0"
                            android:textColor="@color/white"
                            android:textSize="7sp"
                            android:textStyle="bold"
                            android:visibility="gone" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:fontFamily="@font/poppins_regular"
                        android:text="Football"
                        android:textColor="@color/text_muted"
                        android:textSize="8sp" />
                </LinearLayout>

                <!-- Boxing -->
                <LinearLayout
                    android:id="@+id/badgeBoxing"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:gravity="center"
                    android:orientation="vertical">

                    <FrameLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp">

                        <TextView
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:background="@drawable/bg_category_badge"
                            android:gravity="center"
                            android:text="🥊"
                            android:textSize="20sp" />

                        <TextView
                            android:id="@+id/badgeBoxingCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="top|end"
                            android:background="@drawable/bg_badge_counter"
                            android:fontFamily="@font/poppins_regular"
                            android:paddingHorizontal="4dp"
                            android:paddingVertical="0dp"
                            android:text="0"
                            android:textColor="@color/white"
                            android:textSize="7sp"
                            android:textStyle="bold"
                            android:visibility="gone" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:fontFamily="@font/poppins_regular"
                        android:text="Boxing"
                        android:textColor="@color/text_muted"
                        android:textSize="8sp" />
                </LinearLayout>

                <!-- Motorsport -->
                <LinearLayout
                    android:id="@+id/badgeMotor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:gravity="center"
                    android:orientation="vertical">

                    <FrameLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp">

                        <TextView
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:background="@drawable/bg_category_badge"
                            android:gravity="center"
                            android:text="🏎️"
                            android:textSize="20sp" />

                        <TextView
                            android:id="@+id/badgeMotorCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="top|end"
                            android:background="@drawable/bg_badge_counter"
                            android:fontFamily="@font/poppins_regular"
                            android:paddingHorizontal="4dp"
                            android:paddingVertical="0dp"
                            android:text="0"
                            android:textColor="@color/white"
                            android:textSize="7sp"
                            android:textStyle="bold"
                            android:visibility="gone" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:fontFamily="@font/poppins_regular"
                        android:text="Motor"
                        android:textColor="@color/text_muted"
                        android:textSize="8sp" />
                </LinearLayout>

            </LinearLayout>
        </HorizontalScrollView>

        <!-- Status Filter Pills with dynamic counts -->
        <LinearLayout
            android:id="@+id/statusFilters"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="14dp"
            android:paddingBottom="6dp">

            <TextView
                android:id="@+id/filterRecent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_status_pill_active"
                android:fontFamily="@font/poppins_regular"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="✓ Recent (0)"
                android:textColor="@color/primary"
                android:textSize="9sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/filterLive"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_status_pill_live"
                android:fontFamily="@font/poppins_regular"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="● Live (0)"
                android:textColor="@color/live_red"
                android:textSize="9sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/filterUpcoming"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_status_pill"
                android:fontFamily="@font/poppins_regular"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="📅 Upcoming (0)"
                android:textColor="@color/text_muted"
                android:textSize="9sp" />

            <TextView
                android:id="@+id/filterAll"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_status_pill"
                android:fontFamily="@font/poppins_regular"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="✓ All Matches (0)"
                android:textColor="@color/text_muted"
                android:textSize="9sp" />

        </LinearLayout>

        <!-- Match List + Overlays -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/homeRv"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingHorizontal="14dp"
                android:paddingTop="4dp"
                android:paddingBottom="20dp"
                android:layoutAnimation="@anim/layout_anim_fall_down"
                tools:listitem="@layout/view_item_match" />

            <TextView
                android:id="@+id/emptyState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:fontFamily="@font/poppins_regular"
                android:gravity="center"
                android:letterSpacing="0.06"
                android:paddingHorizontal="32dp"
                android:text="@string/fragment_home_empty"
                android:textColor="@color/text_muted"
                android:textSize="14sp"
                android:visibility="gone" />

            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:id="@+id/loadingIndicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:indeterminate="true"
                android:visibility="gone"
                app:indicatorColor="@color/primary"
                app:indicatorSize="40dp"
                app:trackThickness="3dp" />

        </FrameLayout>

    </LinearLayout>

</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
