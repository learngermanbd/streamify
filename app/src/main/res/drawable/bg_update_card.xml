<?xml version="1.0" encoding="utf-8"?>
<!--
    Phase 6 · Step 6.2 — Update dialog card background.

    Reuses the same glass-primary fill as [bg_glass_card] but with a
    subtle radial-gradient inner accent so the card pops on the dark
    splash / main background without competing with the LIVE badge.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:angle="135"
        android:startColor="@color/glass_primary"
        android:endColor="@color/card_bg"
        android:type="linear" />
    <corners android:radius="20dp" />
    <stroke
        android:width="1dp"
        android:color="@color/glass_primary_border" />
</shape>
