<?xml version="1.0" encoding="utf-8"?>
<!--
    Phase 1 · Step 1.5 — Player overlay background.
    8% primary fill + 1dp primary stroke + 8dp corners (tighter than card glass).
    Used by phase 4 (PlayerActivity).
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
       android:shape="rectangle">
    <solid android:color="@color/glass_primary" />
    <stroke
        android:width="1dp"
        android:color="@color/glass_primary_border" />
    <corners android:radius="8dp" />
</shape>
