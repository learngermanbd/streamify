<?xml version="1.0" encoding="utf-8"?>
<!--
  Phase 7 · Step 7.7 — Network security configuration.
  
  Enforces:
    1. No cleartext (HTTP) traffic on any connection.
    2. Only system CA certificates are trusted (user-installed CAs
       are blocked, preventing MITM via proxy tools like Charles).
    3. Certificate pinning for the API domain with primary + backup
       pins.
  
  To generate real pins:
    openssl s_client -connect streamify-4phj.onrender.com:443 -servername streamify-4phj.onrender.com < /dev/null 2>/dev/null \
      | openssl x509 -pubkey -noout \
      | openssl pkey -pubin -outform DER \
      | openssl dgst -sha256 -binary \
      | base64
  
  The backup pin should be from a different CA or an offline key
  that can be rotated if the primary CA is compromised.
-->
<network-security-config>
    <!-- Block cleartext globally — all connections must use TLS. -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <!-- Only trust system-installed CA certificates.
                 User-installed CAs are NOT trusted, blocking MITM
                 via proxy tools (Charles, Burp Suite, etc.). -->
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Certificate pinning is NOT enforced for Render's shared
         *.onrender.com certificate (managed by Render, rotates).
         When moving to a custom domain, re-enable pinning below. -->
    <!--
    <domain-config>
        <domain includeSubdomains="true">streamify-4phj.onrender.com</domain>
        <pin-set expiration="2027-01-01">
            <pin digest="SHA-256">PIN_HERE</pin>
            <pin digest="SHA-256">BACKUP_PIN_HERE</pin>
        </pin-set>
    </domain-config>
    -->
</network-security-config>
